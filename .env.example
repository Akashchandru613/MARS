# ─────────────────────────────────────────────────────────────────────────────
# MARS — Multi-Agent Research System  |  Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Model to use (free on Groq)
GROQ_MODEL=llama-3.1-70b-versatile

# Max tokens per LLM response
MAX_TOKENS=4096

# Temperature (0 = deterministic, best for fact-checking)
TEMPERATURE=0.2

# Search settings
MAX_SEARCH_RESULTS=5       # results per sub-question
MAX_DOCS_PER_QUERY=3       # top-N after reranking
